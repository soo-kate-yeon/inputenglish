{
  "id": "podcast-ambient",
  "name": "Podcast Ambient",
  "description": "Thumbnail-driven ambient playback mood with neutral controls and crisp white list views.",
  "schemaVersion": "2.1",
  "brandTone": "calm",
  "designDNA": {
    "moodKeywords": ["immersive", "ambient", "cinematic", "calm"],
    "targetEmotion": "focused immersion",
    "visualAtmosphere": "podcast app with blurred artwork-tinted now-playing surfaces",
    "principles": [
      "Artwork First Ambient Tint",
      "Neutral White Controls on Session Surfaces",
      "Crisp White List View With Black Type"
    ]
