        "secondary": "inline-flex items-center justify-center rounded-full bg-[var(--bg-secondary)] px-4 py-2 text-sm font-medium text-[var(--text-primary)]",
        "player": "inline-flex items-center justify-center rounded-full bg-white/90 text-neutral-900 backdrop-blur-md font-semibold",
        "ghost": "inline-flex items-center justify-center rounded-full px-4 py-2 text-sm font-medium text-[var(--text-secondary)] hover:bg-[var(--bg-muted)]"
      },
      "input": {
        "list": "w-full rounded-[12px] border border-[var(--border-default)] bg-white px-3 py-2 text-[var(--text-primary)] placeholder:text-[var(--text-secondary)]",
