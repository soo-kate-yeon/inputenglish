    "backdrop": {
      "blur": "24px",
      "saturate": "1.2",
      "brightness": "0.92"
    },
    "overlay": {
      "session": "linear-gradient(180deg, rgba(10,12,16,0.18) 0%, rgba(10,12,16,0.44) 100%)",
      "modal": "linear-gradient(180deg, rgba(10,12,16,0.24) 0%, rgba(10,12,16,0.52) 100%)"
    }
  },
  "aiContext": {
    "designPhilosophy": "Derive atmosphere from artwork, keep controls neutral, and preserve strong readability by switching to white list surfaces outside active sessions.",
    "colorGuidance": "For now-playing and modal contexts, use artwork-tinted dark/warm backgrounds with strong blur and white controls. For list/feed contexts, use white surfaces with near-black text.",
    "componentGuidance": "Primary controls in session contexts should be white or white-alpha. Generic app actions on list pages should remain neutral dark.",
    "spacingGuidance": "Maintain comfortable touch spacing and generous vertical rhythm for transcript and queue lists.",
    "accessibilityNotes": "Ensure 4.5:1 contrast in list mode and >=3:1 for iconography over tinted session overlays."
  }
}
