      },
      "badge": {
        "default": "inline-flex items-center rounded-full bg-[var(--bg-primary)] px-2.5 py-0.5 text-xs font-semibold text-[var(--bg-primary-foreground)]",
        "session": "inline-flex items-center rounded-full bg-white/18 px-2.5 py-0.5 text-xs font-medium text-white"
      },
      "typography": {
        "h1": "text-4xl font-semibold tracking-tight text-[var(--text-primary)]",
        "h2": "text-3xl font-semibold tracking-tight text-[var(--text-primary)]",
        "h3": "text-xl font-semibold text-[var(--text-primary)]",
        "body": "text-base leading-relaxed text-[var(--text-secondary)]",
        "caption": "text-sm text-[var(--text-muted)]",
        "sessionTitle": "text-3xl font-semibold tracking-tight text-white",
        "sessionBody": "text-base leading-relaxed text-white/82"
      },
      "layout": {
        "list": "bg-white min-h-screen",
        "session": "relative min-h-screen text-white",
        "modal": "relative rounded-[18px]",
        "container": "max-w-6xl mx-auto px-6",
        "section": "py-16",
        "grid": "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
      },
      "audio": {
