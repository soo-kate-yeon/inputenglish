# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Generative AI
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Sentry (Mobile)
# Create a React Native project at https://sentry.io, copy its DSN here.
# Leave empty to disable Sentry (app still runs fine).
EXPO_PUBLIC_SENTRY_DSN=

# Azure Speech Services (Web — pronunciation analysis)
# Required for /api/pronunciation/analyses. Without these, requests fail
# with AzurePronunciationError code=MISSING_CONFIG.
# Create a Speech resource at https://portal.azure.com and copy:
#   KEY 1 -> AZURE_SPEECH_KEY
#   Location/Region (lowercase, no spaces, e.g. koreacentral) -> AZURE_SPEECH_REGION
# In production these MUST be registered via `vercel env add`, not just .env.local.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
