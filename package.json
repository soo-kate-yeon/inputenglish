{
  "name": "inputenglish-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo run dev --filter=@inputenglish/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "cd apps/mobile && npx jest --no-coverage --passWithNoTests --testPathIgnorePatterns='ContextBriefCard|HighlightBottomSheet|professional-study-flow|professional-discovery-flow'",
    "type-check": "turbo run type-check",
    "prepare": "husky",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "eslint": "^9.39.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "turbo": "^2.0.0",
    "typescript": "^5"
  },
  "overrides": {
    "@framingui/ui": {
      "@framingui/tokens": "0.3.3"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "expo": "~52.0.49",
    "react": "18.3.1",
    "react-native": "0.76.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ffmpeg-static"
    ]
  }
}
