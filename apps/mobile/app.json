{
  "expo": {
    "name": "Shadowoo",
    "slug": "shadowoo",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "shadowoo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "kr.shadowoo.app",
      "buildNumber": "1",
      "entitlements": {
        "aps-environment": "production"
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Recording your voice for shadowing practice",
        "NSLocalNetworkUsageDescription": "Connect to the local development server while testing on your device"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "kr.shadowoo.app",
      "versionCode": 1,
      "permissions": ["RECORD_AUDIO"]
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-av"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
