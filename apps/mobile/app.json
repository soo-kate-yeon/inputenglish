{
  "expo": {
    "name": "인풋영어",
    "slug": "inputenglish",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "inputenglish",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.morak.inputenglish",
      "buildNumber": "1",
      "entitlements": {
        "aps-environment": "production"
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Recording your voice for shadowing practice",
        "NSLocalNetworkUsageDescription": "Connect to the local development server while testing on your device",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.morak.inputenglish",
      "versionCode": 1,
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-av",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": "1.0.0",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "eb997408-beaa-4636-b0fc-dc54b5542599"
      }
    },
    "owner": "sooyeon-kate",
    "updates": {
      "url": "https://u.expo.dev/eb997408-beaa-4636-b0fc-dc54b5542599"
    }
  }
}
