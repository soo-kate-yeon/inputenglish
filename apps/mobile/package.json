{
  "name": "@inputenglish/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "eas-build-pre-install": "cd ../.. && pnpm install --frozen-lockfile"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/\\.pnpm/(?!((jest-)?react-native|@react-native|expo(nent)?|@expo(nent)?|react-navigation|@react-navigation|@unimodules|unimodules|sentry-expo|native-base|react-native-svg))"
    ],
    "moduleNameMapper": {
      "^react-native-mmkv$": "<rootDir>/src/__mocks__/react-native-mmkv.ts",
      "^@expo/vector-icons(.*)$": "<rootDir>/src/__mocks__/@expo/vector-icons.ts"
    }
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@expo/vector-icons": "^14.0.0",
    "@inputenglish/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@supabase/supabase-js": "^2.49.1",
    "expo": "~52.0.0",
    "expo-apple-authentication": "^55.0.12",
    "expo-asset": "^55.0.10",
    "expo-auth-session": "^5.5.2",
    "expo-av": "~15.0.2",
    "expo-blur": "~14.0.3",
    "expo-constants": "~17.0.3",
    "expo-crypto": "^14.0.1",
    "expo-dev-client": "~5.0.20",
    "expo-device": "~7.0.2",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.3",
    "expo-notifications": "~0.29.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "^14.0.0",
    "expo-speech": "~13.0.1",
    "expo-splash-screen": "~0.29.18",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.6",
    "expo-updates": "~0.27.5",
    "expo-web-browser": "^14.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.3",
    "react-native-mmkv": "^3.2.0",
    "react-native-purchases": "^9.11.2",
    "react-native-purchases-ui": "^9.11.2",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.3.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-webview": "^13.16.1",
    "react-native-youtube-iframe": "^2.4.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/react-native": "^13.0.0",
    "@types/react": "~18.3.12",
    "@types/react-native": "^0.73.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "typescript": "~5.7.2"
  }
}
