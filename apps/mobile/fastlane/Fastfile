default_platform(:ios)

platform :ios do
  # ─────────────────────────────────────────────
  # Metadata Management
  # ─────────────────────────────────────────────

  desc "Upload metadata to App Store Connect (no binary)"
  lane :upload_metadata do
    deliver(
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  desc "Upload screenshots to App Store Connect"
  lane :upload_screenshots do
    deliver(
      skip_binary_upload: true,
      skip_metadata: true,
      force: true,
      overwrite_screenshots: true
    )
  end

  desc "Upload metadata + screenshots"
  lane :upload_all_metadata do
    deliver(
      skip_binary_upload: true,
      force: true,
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  desc "Download existing metadata from App Store Connect"
  lane :download_metadata do
    deliver(
      download_metadata: true,
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true
    )
  end

  desc "Download existing screenshots from App Store Connect"
  lane :download_screenshots do
    deliver(
      download_screenshots: true,
      skip_binary_upload: true,
      skip_metadata: true,
      force: true
    )
  end

  # ─────────────────────────────────────────────
  # Screenshots (Automated via Simulator)
  # ─────────────────────────────────────────────

  desc "Capture screenshots via Maestro automation (4 screens × 4 devices)"
  lane :screenshots do
    maestro_bin = "#{Dir.home}/.maestro/bin/maestro"
    unless File.exist?(maestro_bin)
      UI.user_error!("Maestro not found. Install: curl -Ls 'https://get.maestro.mobile.dev' | bash")
    end

    devices = [
      { name: "iPhone 17 Pro Max",     prefix: "iPhone_17_Pro_Max" },
      { name: "iPhone 17 Pro",         prefix: "iPhone_17_Pro" },
      { name: "iPhone 16e",            prefix: "iPhone_16e" },
      { name: "iPad Pro 13-inch (M5)", prefix: "iPad_Pro_13_inch_M5" }
    ]

    flows     = ["01_home", "02_brief", "03_listening", "04_archive"]
    flows_dir = File.expand_path("fastlane/screenshots/flows")
    out_dir   = File.expand_path("fastlane/screenshots/ko")
    FileUtils.mkdir_p(out_dir)

    devices.each do |device|
      UI.message("📱 #{device[:name]}")

      udid = sh(
        "xcrun simctl list devices | grep '#{device[:name]}' | grep -v 'unavailable' | head -1 | grep -oE '[0-9A-F-]{36}' || true"
      ).strip

      if udid.empty?
        UI.important("  ⚠️  Simulator not found: #{device[:name]} — skipping")
        next
      end

      booted = sh("xcrun simctl list devices booted | grep '#{udid}' || true").strip
      if booted.empty?
        UI.message("  🔄 Booting...")
        sh("xcrun simctl boot #{udid}")
        sleep(6)
      end

      flows.each do |flow|
        UI.message("  📸 #{flow}")
        sh(
          "#{maestro_bin} --device #{udid} test #{flows_dir}/#{flow}.yaml" \
          " --env OUTPUT_DIR=#{out_dir} --env DEVICE_PREFIX=#{device[:prefix]} || true"
        )
      end

      UI.success("  ✅ Done")
    end

    UI.success("🎉 Screenshots saved → fastlane/screenshots/ko/")
  end

  # ─────────────────────────────────────────────
  # Version Management
  # ─────────────────────────────────────────────

  desc "Bump version number"
  lane :bump_version do |options|
    type = options[:type] || "patch" # major, minor, patch
    current = get_version_number_from_app_json
    new_version = bump_semver(current, type)
    update_app_json_version(new_version)
    UI.success("Version bumped: #{current} -> #{new_version}")
  end

  # ─────────────────────────────────────────────
  # Full Release Pipeline
  # ─────────────────────────────────────────────

  desc "Full release: metadata + EAS build + submit"
  lane :release do |options|
    # Step 1: Upload metadata
    upload_metadata

    # Step 2: Trigger EAS build (runs externally)
    UI.important("Run EAS build separately:")
    UI.message("  eas build --platform ios --profile production --non-interactive")
    UI.message("Then submit with:")
    UI.message("  eas submit --platform ios --latest")
  end

  # ─────────────────────────────────────────────
  # Helpers
  # ─────────────────────────────────────────────

  def get_version_number_from_app_json
    app_json = JSON.parse(File.read("../app.json"))
    app_json["expo"]["version"]
  end

  def update_app_json_version(new_version)
    app_json_path = "../app.json"
    app_json = JSON.parse(File.read(app_json_path))
    app_json["expo"]["version"] = new_version
    File.write(app_json_path, JSON.pretty_generate(app_json) + "\n")
  end

  def bump_semver(version, type)
    parts = version.split(".").map(&:to_i)
    case type
    when "major"
      "#{parts[0] + 1}.0.0"
    when "minor"
      "#{parts[0]}.#{parts[1] + 1}.0"
    when "patch"
      "#{parts[0]}.#{parts[1]}.#{parts[2] + 1}"
    end
  end
end
